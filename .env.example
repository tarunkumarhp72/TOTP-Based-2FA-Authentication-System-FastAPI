# Application
APP_NAME=TOTP 2FA Auth Service
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=False
SECRET_KEY=change-me-in-production-use-32-char-minimum

# Database (PostgreSQL with asyncpg)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/your-database-name
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_ECHO=False

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_POOL_SIZE=10

# JWT
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_SECRET_KEY=change-me-jwt-secret-32-char-minimum

# Security
BCRYPT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15
TOTP_ISSUER=TOTP Auth Service
TOTP_BACKUP_CODE_COUNT=10

# CORS
ALLOWED_ORIGINS=["http://localhost:3000"]
ALLOWED_HOSTS=["localhost","127.0.0.1"]

# Request
MAX_REQUEST_SIZE_BYTES=1048576
REQUEST_TIMEOUT_SECONDS=30

# Note: Rate limiting is now configured via decorators in the code, not in .env
